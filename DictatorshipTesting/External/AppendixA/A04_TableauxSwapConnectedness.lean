import Mathlib.Data.List.Pairwise
import DictatorshipTesting.Paper.S05_Int_YoungOrthogonal

/-
Direct reverse imports:
- `DictatorshipTesting`
- `DictatorshipTesting.Paper.AppA_LemA_04_StandardTableauxSwapConnectedness`
-/

/-!
# Appendix A.4: standard-tableau swap connectedness, first internal layer

This file starts replacing the Appendix A.4 external input with actual Lean
proofs.

The theorem below proves the elementary finite-list fact needed for the usual
linear-extension argument: adjacent swaps of incomparable neighboring elements
preserve the linear-extension condition.  The standard-tableau connectedness
statement is also exposed below.  Its paper-facing wrapper remains an external
axiom until the linear-extension argument is specialized to standard Young
tableaux.
-/

noncomputable section

namespace DictatorshipTesting

namespace External
namespace AppendixA

variable {α : Type*}

/-- Two elements are incomparable for a strict order-like relation `lt`. -/
def Incomparable (lt : α -> α -> Prop) (a b : α) : Prop :=
  ¬ lt a b ∧ ¬ lt b a

/-- A list model for a linear extension of a finite strict poset.  The list has
no duplicates, and no later entry is required by `lt` to precede an earlier
entry. -/
def IsLinearExtension (lt : α -> α -> Prop) (xs : List α) : Prop :=
  xs.Nodup ∧ xs.Pairwise (fun a b => ¬ lt b a)

/-- One adjacent swap of incomparable neighboring entries. -/
def AdjacentIncomparableSwap (lt : α -> α -> Prop) (xs ys : List α) : Prop :=
  ∃ pre post a b,
    Incomparable lt a b ∧
      xs = pre ++ a :: b :: post ∧
      ys = pre ++ b :: a :: post

/-- Reachability generated by adjacent swaps of incomparable neighboring
entries.  This is the abstract graph relation that the tableau specialization
should eventually instantiate. -/
def LinearExtensionSwapReachable (lt : α -> α -> Prop) (xs ys : List α) : Prop :=
  Relation.ReflTransGen (AdjacentIncomparableSwap lt) xs ys

theorem adjacentIncomparableSwap_symm {lt : α -> α -> Prop} {xs ys : List α}
    (h : AdjacentIncomparableSwap lt xs ys) :
    AdjacentIncomparableSwap lt ys xs := by
  rcases h with ⟨pre, post, a, b, hinc, rfl, rfl⟩
  exact ⟨pre, post, b, a, ⟨hinc.2, hinc.1⟩, rfl, rfl⟩

theorem nodup_adjacent_swap {pre post : List α} {a b : α}
    (h : (pre ++ a :: b :: post).Nodup) :
    (pre ++ b :: a :: post).Nodup := by
  have hp : (pre ++ b :: a :: post).Perm (pre ++ a :: b :: post) := by
    exact List.Perm.append_left _ (List.Perm.swap _ _ _)
  exact hp.nodup_iff.mpr h

/-- Swapping adjacent incomparable entries preserves the list-level
linear-extension predicate. -/
theorem isLinearExtension_adjacent_swap {lt : α -> α -> Prop}
    {pre post : List α} {a b : α}
    (hlin : IsLinearExtension lt (pre ++ a :: b :: post))
    (hinc : Incomparable lt a b) :
    IsLinearExtension lt (pre ++ b :: a :: post) := by
  classical
  rcases hlin with ⟨hnodup, hpair⟩
  refine ⟨nodup_adjacent_swap hnodup, ?_⟩
  let R : α -> α -> Prop := fun x y => ¬ lt y x
  change (pre ++ b :: a :: post).Pairwise R
  change (pre ++ a :: b :: post).Pairwise R at hpair
  rw [List.pairwise_append] at hpair ⊢
  rcases hpair with ⟨hpre, htail, hcross⟩
  rw [List.pairwise_cons] at htail
  rcases htail with ⟨ha_all, hbtail⟩
  rw [List.pairwise_cons] at hbtail
  rcases hbtail with ⟨hb_post, hpost⟩
  refine ⟨hpre, ?_, ?_⟩
  · rw [List.pairwise_cons]
    refine ⟨?_, ?_⟩
    · intro y hy
      rcases List.mem_cons.mp hy with rfl | hy
      · simpa [R] using hinc.1
      · exact hb_post y hy
    · rw [List.pairwise_cons]
      refine ⟨?_, hpost⟩
      intro y hy
      exact ha_all y (by simp [hy])
  intro x hx y hy
  have hy' : y ∈ a :: b :: post := by
    simp only [List.mem_cons] at hy ⊢
    tauto
  exact hcross x hx y hy'

/-- The same preservation statement phrased for one abstract adjacent-swap
edge. -/
theorem isLinearExtension_of_adjacentIncomparableSwap {lt : α -> α -> Prop}
    {xs ys : List α}
    (hstep : AdjacentIncomparableSwap lt xs ys)
    (hlin : IsLinearExtension lt xs) :
    IsLinearExtension lt ys := by
  rcases hstep with ⟨pre, post, a, b, hinc, rfl, rfl⟩
  exact isLinearExtension_adjacent_swap hlin hinc

/-- One edge in the standard-tableau adjacent-swap graph of a fixed shape. -/
def StandardTableauxAdjacent {n : Nat} {lam : YoungDiagram (n + 1)}
    (T U : StandardYoungTableau lam) : Prop :=
  ∃ (a : Fin n) (hrow : ¬ adjacentSameRow T a)
    (hcol : ¬ adjacentSameCol T a),
    U = adjacentSwapTableau T a hrow hcol

/-- Appendix A.4 connectedness statement: any two standard tableaux of the same
shape are connected by adjacent swaps that remain standard. -/
def StandardTableauxSwapConnectedStatement : Prop :=
  ∀ {n : Nat} (lam : YoungDiagram (n + 1))
    (T U : StandardYoungTableau lam),
    Relation.ReflTransGen (StandardTableauxAdjacent (lam := lam)) T U

end AppendixA
end External

end DictatorshipTesting
